{
  "formula": [
    "const selection = $map.getSelectionIds();",
    "if (selection.length === 0) {",
    "    $tools.toast('Sélection requise', 'Veuillez sélectionner un marqueur.', 'warning');",
    "    return { html: 'Aucun marqueur sélectionné.', data: null };",
    "}",
    "",
    "const marker = $map.getMarker(selection[0]);",
    "let pos = marker.latlng || (await $map.getMarkerBounds(selection[0])).getCenter().toJSON();",
    "const { lat, lng } = pos;",
    "",
    "if (!$context._analysisLayer) $context._analysisLayer = [];",
    "const clearLayer = () => {",
    "    const provider = $map.getMapProvider();",
    "    const mapObj = $map.getMapObject();",
    "    for (const item of $context._analysisLayer) {",
    "        if (provider === 'Leaflet') item.remove();",
    "        else if (provider === 'GoogleMaps') { if (item.setMap) item.setMap(null); else mapObj.data.remove(item); }",
    "    }",
    "    $context._analysisLayer = [];",
    "};",
    "clearLayer();",
    "",
    "const getZoneStyle = (t) => {",
    "    const styles = { 'U': '#e60000', 'AU': '#ffaa00', 'N': '#38a800', 'A': '#ffff00' };",
    "    const k = t?.toUpperCase().charAt(0);",
    "    const color = styles[t?.toUpperCase().substring(0, 2)] || styles[k] || '#8400a8';",
    "    return { color, text: (k === 'A' || t?.includes('AU')) ? 'black' : 'white' };",
    "};",
    "",
    "try {",
    "    const b = 0.006, bbox = `${lat - b},${lng - b},${lat + b},${lng + b}`;",
    "    const [pRes, pluRes, bRes, eRes, addrRes] = await Promise.all([",
    "        fetch(`https://data.geopf.fr/wfs/ows?SERVICE=WFS&VERSION=2.0.0&REQUEST=GetFeature&TYPENAMES=CADASTRALPARCELS.PARCELLAIRE_EXPRESS:parcelle&BBOX=${bbox}&OUTPUTFORMAT=application/json`).then(r => r.json()),",
    "        fetch(`https://data.geopf.fr/wfs/ows?SERVICE=WFS&VERSION=2.0.0&REQUEST=GetFeature&TYPENAMES=wfs_du:zone_urba&BBOX=${bbox}&OUTPUTFORMAT=application/json`).then(r => r.json()),",
    "        fetch(`https://data.geopf.fr/wfs/ows?SERVICE=WFS&VERSION=2.0.0&REQUEST=GetFeature&TYPENAMES=BDTOPO_V3:batiment&BBOX=${bbox}&OUTPUTFORMAT=application/json`).then(r => r.json()),",
    "        fetch(`https://api.open-meteo.com/v1/elevation?latitude=${lat},${lat+0.0004}&longitude=${lng},${lng}`).then(r => r.json()),",
    "        fetch(`https://data.geopf.fr/geocodage/reverse?lat=${lat}&lon=${lng}&index=address&limit=1`).then(r => r.json())",
    "    ]);",
    "",
    "    const pt = turf.point([lng, lat]);",
    "    const circle500 = turf.circle(pt, 0.5, { units: 'kilometers' });",
    "    ",
    "    const parcel = pRes.features.find(f => turf.flatten(f).features.some(p => turf.booleanPointInPolygon(pt, p))) || pRes.features[0];",
    "    if (!parcel) throw new Error(\"Hors périmètre cadastral.\");",
    "",
    "    const pGeom = turf.flatten(parcel).features[0], pArea = turf.area(pGeom);",
    "    const address = addrRes.features?.[0]?.properties?.label || \"Adresse inconnue\";",
    "    const idu = parcel.properties.idu || '-';",
    "    const ref = `${parcel.properties.section || ''} ${parcel.properties.numero || ''}`;",
    "    ",
    "    const provider = $map.getMapProvider(), mapObj = $map.getMapObject();",
    "",
    "    // 1. DESSIN DU CONTEXTE (Opacité légère 0.25)",
    "    for (const zf of pluRes.features) {",
    "        const style = getZoneStyle(zf.properties.typezone);",
    "        const clippedZone = turf.intersect(zf, circle500);",
    "        if (clippedZone) {",
    "            if (provider === 'Leaflet') {",
    "                $context._analysisLayer.push(L.geoJSON(clippedZone, { style: { color: style.color, weight: 1, fillOpacity: 0.25, fillColor: style.color, stroke: false } }).addTo(mapObj));",
    "            } else {",
    "                mapObj.data.addGeoJson(clippedZone).forEach(f => { ",
    "                    mapObj.data.overrideStyle(f, { fillColor: style.color, fillOpacity: 0.25, strokeWeight: 0 }); ",
    "                    $context._analysisLayer.push(f); ",
    "                });",
    "            }",
    "        }",
    "    }",
    "",
    "    // 2. DESSIN DE LA CIBLE (Opacité forte 0.70) et Calcul mixité",
    "    const mixed = [];",
    "    for (const zf of pluRes.features) {",
    "        for (const zp of turf.flatten(zf).features) {",
    "            const inter = turf.intersect(pGeom, zp);",
    "            if (inter && turf.area(inter) > 1) {",
    "                const type = zf.properties.typezone, style = getZoneStyle(type);",
    "                mixed.push({ type, pct: (turf.area(inter)/pArea*100).toFixed(1), style });",
    "                ",
    "                // Dessin de l'intersection avec opacité forte",
    "                if (provider === 'Leaflet') {",
    "                    $context._analysisLayer.push(L.geoJSON(inter, { style: { color: style.color, weight: 0, fillOpacity: 0.7, fillColor: style.color } }).addTo(mapObj));",
    "                } else {",
    "                    mapObj.data.addGeoJson(inter).forEach(f => { ",
    "                        mapObj.data.overrideStyle(f, { fillColor: style.color, fillOpacity: 0.7, strokeWeight: 0 }); ",
    "                        $context._analysisLayer.push(f); ",
    "                    });",
    "                }",
    "            }",
    "        }",
    "    }",
    "",
    "    // 3. Calcul Bâti",
    "    let bArea = 0, bClips = [];",
    "    for (const bf of bRes.features) {",
    "        for (const bp of turf.flatten(bf).features) {",
    "            const inter = turf.intersect(bp, pGeom);",
    "            if (inter) { bArea += turf.area(inter); bClips.push(inter); }",
    "        }",
    "    }",
    "",
    "    // 4. Contour final et Bâtiments (Au-dessus de tout)",
    "    if (provider === 'Leaflet') {",
    "        $context._analysisLayer.push(L.geoJSON(parcel, { style: { color: '#000', weight: 4, fillOpacity: 0 } }).addTo(mapObj));",
    "        if (bClips.length) $context._analysisLayer.push(L.geoJSON({type:'FeatureCollection', features:bClips}, { style: { color: '#2c3e50', weight: 0.5, fillOpacity: 0.8, fillColor: '#2c3e50' } }).addTo(mapObj));",
    "    } else {",
    "        mapObj.data.addGeoJson(parcel).forEach(f => { mapObj.data.overrideStyle(f, { strokeColor: '#000', fillOpacity: 0, strokeWeight: 4 }); $context._analysisLayer.push(f); });",
    "        if (bClips.length) mapObj.data.addGeoJson({type:'FeatureCollection', features:bClips}).forEach(f => { mapObj.data.overrideStyle(f, { fillColor: '#2c3e50', fillOpacity: 0.8, strokeColor: '#000', strokeWeight: 0.5 }); $context._analysisLayer.push(f); });",
    "    }",
    "",
    "    const nonBArea = pArea - bArea;",
    "    const ces = (bArea / pArea * 100).toFixed(1);",
    "    const slope = (Math.abs(eRes.elevation[0] - eRes.elevation[1]) / 45 * 100).toFixed(1);",
    "",
    "    return {",
    "        html: `",
    "        <div class=\"bg-white shadow rounded overflow-hidden border\" style=\"font-size: 0.85rem; border-color: #333 !important;\">",
    "            <div class=\"px-3 py-3 bg-dark text-white d-flex justify-content-between align-items-start\" style=\"line-height: 1.4;\">",
    "                <div class=\"d-flex flex-column\">",
    "                    <div class=\"h6 font-weight-bold mb-2 text-white\" style=\"letter-spacing: 0.5px;\">${address.toUpperCase()}</div>",
    "                    <div class=\"small d-flex align-items-center mb-1\"><span class=\"text-white-50 mr-2\" style=\"min-width: 60px;\">IDU</span> <span class=\"font-weight-bold\">${idu}</span></div>",
    "                    <div class=\"small d-flex align-items-center mb-1\"><span class=\"text-white-50 mr-2\" style=\"min-width: 60px;\">RÉF.</span> <span class=\"font-weight-bold\">${ref}</span></div>",
    "                    <div class=\"small d-flex align-items-center\"><span class=\"text-white-50 mr-2\" style=\"min-width: 60px;\">GPS</span> <span class=\"font-weight-bold\">${lat.toFixed(5)}, ${lng.toFixed(5)}</span></div>",
    "                </div>",
    "                <div class=\"text-right\">",
    "                    <div class=\"text-white-50 font-weight-bold mb-2\" style=\"font-size: 0.65rem; letter-spacing: 1px;\">ZONAGE CIBLE</div>",
    "                    ${mixed.map(z => `",
    "                        <div class=\"d-flex align-items-center justify-content-end mb-1\">",
    "                            <span class=\"badge mr-2\" style=\"background:${z.style.color}; color:${z.style.text}; border: 1px solid rgba(255,255,255,0.2); font-size:0.65rem; padding: 4px 6px;\">ZONE ${z.type}</span>",
    "                            <span class=\"font-weight-bold\" style=\"font-size: 0.85rem;\">${z.pct}%</span>",
    "                        </div>`).join('')}",
    "                </div>",
    "            </div>",
    "            <div class=\"p-3 bg-white\">",
    "                <div class=\"row no-gutters\">",
    "                    <div class=\"col-6 pr-2 border-right\">",
    "                        <div class=\"mb-3\">",
    "                            <div class=\"text-muted x-small font-weight-bold text-uppercase\">Surface Terrain</div>",
    "                            <div class=\"h5 mb-0 font-weight-bold\">${Math.round(pArea).toLocaleString()} m²</div>",
    "                        </div>",
    "                        <div class=\"mb-3\">",
    "                            <div class=\"text-muted x-small font-weight-bold text-uppercase\">Bâti Réel</div>",
    "                            <div class=\"h5 mb-0 font-weight-bold text-danger\">${bArea.toFixed(1)} m²</div>",
    "                        </div>",
    "                        <div>",
    "                            <div class=\"text-muted x-small font-weight-bold text-uppercase\">Non Bâti</div>",
    "                            <div class=\"h5 mb-0 font-weight-bold text-success\">${nonBArea.toFixed(1)} m²</div>",
    "                        </div>",
    "                    </div>",
    "                    <div class=\"col-6 pl-3\">",
    "                        <div class=\"mb-3\">",
    "                            <div class=\"text-muted x-small font-weight-bold text-uppercase\">Emprise (CES)</div>",
    "                            <div class=\"h5 mb-0 font-weight-bold\">${ces} %</div>",
    "                        </div>",
    "                        <div class=\"mb-3\">",
    "                            <div class=\"text-muted x-small font-weight-bold text-uppercase\">Altitude</div>",
    "                            <div class=\"h5 mb-0 font-weight-bold\">${eRes.elevation[0].toFixed(0)} m</div>",
    "                        </div>",
    "                        <div>",
    "                            <div class=\"text-muted x-small font-weight-bold text-uppercase\">Pente Moyenne</div>",
    "                            <div class=\"h5 mb-0 font-weight-bold\">${slope} %</div>",
    "                        </div>",
    "                    </div>",
    "                </div>",
    "            </div>",
    "            <div class=\"px-3 py-1 bg-light text-center text-muted border-top\" style=\"font-size: 0.6rem; letter-spacing: 0.5px;\">",
    "                DONNÉES OFFICIELLES GÉOPLATEFORME IGN • OPACITÉ CIBLE RENFORCÉE",
    "            </div>",
    "        </div>`,",
    "        data: { idu, ref, address, lat, lng, surface_terrain: pArea, surface_batie: bArea, surface_non_batie: nonBArea, ces, altitude: eRes.elevation[0], pente: parseFloat(slope) },",
    "        reset: clearLayer",
    "    };",
    "} catch (e) {",
    "    console.error(e);",
    "    return { html: `<div class=\"alert alert-danger p-3 shadow-sm\"><strong>Erreur d'Audit :</strong><br>${e.message}</div>`, data: null, reset: clearLayer };",
    "}"
  ],
  "description": "Analyse foncière : la parcelle auditée affiche son zonage PLU, bâti réel et non bâti.",
  "title": "Audit Parcellaire",
  "output": {
    "idu": "string",
    "ref": "string",
    "address": "string",
    "lat": "number",
    "lng": "number",
    "surface_terrain": "number",
    "surface_batie": "number",
    "surface_non_batie": "number",
    "ces": "string",
    "altitude": "number",
    "pente": "number"
  },
  "mode": "SINGLE-POINT",
  "ownerId": "benoit.terrasa@localflow.fr",
  "tags": [
    "france",
    "parcelle",
    "foncier"
  ]
}