{
  "formula": [
    "const selectionIds = $map.getSelectionIds();",
    "let center;",
    "",
    "if (selectionIds.length > 0) {",
    "    const marker = $map.getMarker(selectionIds[0]);",
    "    center = marker.latlng || $map.getMarkerBounds(selectionIds[0]).getCenter().toJSON();",
    "} else {",
    "    const mapObj = $map.getMapObject();",
    "    center = ($map.getMapProvider() === 'GoogleMaps') ? mapObj.getCenter().toJSON() : mapObj.getCenter();",
    "}",
    "",
    "const getEffectifLabel = (code) => {",
    "    const map = {",
    "        'NN': 'Non renseigné', '00': '0 salarié', '01': '1-2', '02': '3-5', '03': '6-9', '11': '10-19', ",
    "        '12': '20-49', '21': '50-99', '22': '100-199', '31': '200-249', '32': '250-499', ",
    "        '41': '500-999', '42': '1000-1999', '51': '2000-4999', '52': '5000-9999', '53': '10 000+'",
    "    };",
    "    return map[code] || 'Inconnu';",
    "};",
    "",
    "const radius = 50;",
    "const url = `https://recherche-entreprises.api.gouv.fr/near_point?lat=${center.lat}&long=${center.lng}&radius=${radius}&activite_principale=71.12B&categorie_entreprise=GE&per_page=25`;",
    "",
    "let localOffices = [];",
    "try {",
    "    const response = await fetch(url);",
    "    const result = await response.json();",
    "    const companies = result.results || [];",
    "    const centerPoint = turf.point([center.lng, center.lat]);",
    "",
    "    for (const company of companies) {",
    "        if (company.matching_etablissements) {",
    "            for (const etab of company.matching_etablissements) {",
    "                const lat = parseFloat(etab.latitude);",
    "                const lng = parseFloat(etab.longitude);",
    "                if (!isNaN(lat) && !isNaN(lng)) {",
    "                    const distance = turf.distance(centerPoint, turf.point([lng, lat]), { units: 'kilometers' });",
    "                    if (distance <= radius) {",
    "                        localOffices.push({",
    "                            id: `off-${etab.siret}`,",
    "                            nom: company.nom_complet,",
    "                            siren: company.siren,",
    "                            siret: etab.siret,",
    "                            adresse: etab.adresse,",
    "                            ville: etab.libelle_commune,",
    "                            effectifs: getEffectifLabel(etab.tranche_effectif_salarie),",
    "                            dirigeants: company.dirigeants || [],",
    "                            lat, lng, dist: distance.toFixed(1)",
    "                        });",
    "                    }",
    "                }",
    "            }",
    "        }",
    "    }",
    "} catch (e) { console.error(e); }",
    "",
    "$context._analysisLayer = $context._analysisLayer || [];",
    "const clearLayer = () => {",
    "    for (const item of $context._analysisLayer) {",
    "        if ($map.getMapProvider() === 'GoogleMaps') item.setMap(null);",
    "        else item.remove();",
    "    }",
    "    $context._analysisLayer = [];",
    "};",
    "clearLayer();",
    "",
    "const html = `",
    "<div class=\"container-fluid p-0\">",
    "    <div class=\"card border-0 bg-dark text-white mb-2 shadow-sm\">",
    "        <div class=\"card-body p-2 d-flex justify-content-between align-items-center\">",
    "            <h6 class=\"m-0 font-weight-bold small\">SITES GRANDS GROUPES (50KM)</h6>",
    "            <span class=\"badge badge-warning\">${localOffices.length} Bureaux</span>",
    "        </div>",
    "    </div>",
    "",
    "    <div id=\"deep-detail\" class=\"card border-warning mb-2 d-none shadow-sm\">",
    "        <div class=\"card-body p-2\">",
    "            <div class=\"d-flex justify-content-between mb-1\">",
    "                <h6 id=\"d-name\" class=\"text-primary font-weight-bold m-0 small text-truncate\" style=\"max-width: 80%;\">-</h6>",
    "                <span class=\"badge badge-warning text-white\" style=\"font-size: 0.6rem;\">GE</span>",
    "            </div>",
    "            <div class=\"p-2 bg-light rounded mb-2\">",
    "                <div class=\"x-small text-muted mb-1\"><b>ADRESSE :</b> <span id=\"d-addr\">-</span></div>",
    "                <div class=\"x-small\"><b>EFFECTIFS SITE :</b> <span id=\"d-eff\" class=\"text-success font-weight-bold\">-</span></div>",
    "            </div>",
    "            <div class=\"mb-2\">",
    "                <div class=\"x-small font-weight-bold mb-1 border-bottom\">DIRIGEANTS DU GROUPE</div>",
    "                <div id=\"d-dir\" class=\"x-small text-muted\" style=\"max-height: 60px; overflow-y: auto;\">-</div>",
    "            </div>",
    "            <div class=\"border-top pt-1\">",
    "                <div class=\"x-small d-flex justify-content-between\">",
    "                    <span><b>DENSITÉ (200m) :</b></span>",
    "                    <span id=\"d-density\" class=\"text-info font-weight-bold\">-</span>",
    "                </div>",
    "            </div>",
    "        </div>",
    "    </div>",
    "",
    "    <div class=\"table-responsive\" style=\"max-height: 20rem;\">",
    "        <table class=\"table table-sm table-hover\">",
    "            <thead class=\"thead-light x-small\">",
    "                <tr><th>Groupe / Localisation</th><th class=\"text-right\">Dist.</th></tr>",
    "            </thead>",
    "            <tbody id=\"office-table-body\" style=\"font-size: 0.78rem;\">",
    "                ${localOffices.map(o => `",
    "                    <tr style=\"cursor:pointer\" class=\"office-row\" id=\"row-${o.id}\" data-id=\"${o.id}\">",
    "                        <td class=\"py-2 text-truncate\" style=\"max-width: 180px;\">",
    "                            <div class=\"font-weight-bold\">${o.nom}</div>",
    "                            <div class=\"x-small text-muted\">${o.ville} • ${o.effectifs}</div>",
    "                        </td>",
    "                        <td class=\"text-right align-middle text-info font-weight-bold\">${o.dist}km</td>",
    "                    </tr>",
    "                `).join('')}",
    "            </tbody>",
    "        </table>",
    "    </div>",
    "</div>",
    "<style>.x-small { font-size: 0.7rem; } .table-warning { background-color: rgba(253, 126, 20, 0.15) !important; }</style>",
    "`;",
    "",
    "requestAnimationFrame(() => {",
    "    const detail = document.getElementById('deep-detail');",
    "    const dName = document.getElementById('d-name');",
    "    const dAddr = document.getElementById('d-addr');",
    "    const dEff = document.getElementById('d-eff');",
    "    const dDir = document.getElementById('d-dir');",
    "    const dDens = document.getElementById('d-density');",
    "",
    "    const showOfficeDetails = async (o) => {",
    "        detail.classList.remove('d-none');",
    "        dName.innerText = o.nom;",
    "        dAddr.innerText = o.adresse;",
    "        dEff.innerText = o.effectifs;",
    "        dDir.innerHTML = o.dirigeants.length > 0 ",
    "            ? o.dirigeants.map(d => `<div>• ${d.prenoms || ''} ${d.nom || ''} <span class=\"text-muted small\">(${d.qualite || 'Dirigeant'})</span></div>`).join('')",
    "            : 'Non disponible';",
    "        ",
    "        $map.panTo({ lat: o.lat, lng: o.lng });",
    "        ",
    "        // Highlight table row",
    "        document.querySelectorAll('.office-row').forEach(r => r.classList.remove('table-warning'));",
    "        const row = document.getElementById(`row-${o.id}`);",
    "        if (row) {",
    "            row.classList.add('table-warning');",
    "            row.scrollIntoView({ behavior: 'smooth', block: 'nearest' });",
    "        }",
    "",
    "        dDens.innerText = 'Calcul...';",
    "        try {",
    "            const opUrl = `https://overpass-api.de/api/interpreter?data=[out:json];(node[\"office\"](around:200,${o.lat},${o.lng});way[\"office\"](around:200,${o.lat},${o.lng}););out count;`;",
    "            const opRes = await fetch(opUrl);",
    "            const opData = await opRes.json();",
    "            const count = opData.elements[0]?.tags?.total || 0;",
    "            dDens.innerHTML = `${count} bureaux voisins`;",
    "        } catch (e) { dDens.innerText = 'N/A'; }",
    "    };",
    "",
    "    // Ajout des marqueurs avec interaction",
    "    for (const o of localOffices) {",
    "        const color = '#fd7e14';",
    "        if ($map.getMapProvider() === 'GoogleMaps') {",
    "            const m = new google.maps.Marker({",
    "                position: { lat: o.lat, lng: o.lng },",
    "                map: $map.getMapObject(),",
    "                icon: { path: google.maps.SymbolPath.CIRCLE, scale: 9, fillColor: color, fillOpacity: 0.9, strokeWeight: 2, strokeColor: '#fff' }",
    "            });",
    "            m.addListener('click', () => showOfficeDetails(o));",
    "            $context._analysisLayer.push(m);",
    "        } else {",
    "            const m = L.circleMarker([o.lat, o.lng], {",
    "                radius: 9, fillColor: color, color: '#fff', weight: 2, opacity: 1, fillOpacity: 0.9",
    "            }).addTo($map.getMapObject());",
    "            m.on('click', () => showOfficeDetails(o));",
    "            $context._analysisLayer.push(m);",
    "        }",
    "    }",
    "",
    "    // Interaction Table",
    "    document.querySelectorAll('.office-row').forEach(row => {",
    "        row.addEventListener('click', () => {",
    "            const office = localOffices.find(o => o.id === row.dataset.id);",
    "            if (office) showOfficeDetails(office);",
    "        });",
    "    });",
    "});",
    "",
    "return { html, data: localOffices, reset: clearLayer };"
  ],
  "description": "Analyse d'intelligence économique sur les bureaux d'ingénierie des grandes entreprises (GE). L'interface offre une interactivité bidirectionnelle complète : cliquer sur un marqueur orange ou sur une ligne du tableau affiche instantanément les dirigeants, les effectifs locaux et une analyse de densité de voisinage (OSM).",
  "title": "Bureaux Stratégiques (GE)",
  "output": {
    "nom": "string",
    "siret": "string",
    "adresse": "string",
    "effectifs": "string",
    "dirigeants": "array",
    "lat": "number",
    "lng": "number"
  },
  "mode": "SINGLE-POINT",
  "ownerId": "renaud.pawlak.dev481@agentforce.com",
  "tags": [ "france", "esn", "grands groupes", "bureaux", "intelligence économique" ]
}