{
  "formula": [
    "const selectionIds = $map.getSelectionIds();",
    "let center;",
    "",
    "if (selectionIds.length > 0) {",
    "    const marker = $map.getMarker(selectionIds[0]);",
    "    center = marker.latlng || $map.getMarkerBounds(selectionIds[0]).getCenter().toJSON();",
    "} else {",
    "    const mapObj = $map.getMapObject();",
    "    center = ($map.getMapProvider() === 'GoogleMaps') ? mapObj.getCenter().toJSON() : mapObj.getCenter();",
    "}",
    "",
    "const sectors = [",
    "    { code: '71.12B', label: 'Ingénierie Technique' },",
    "    { code: '62.01Z', label: 'Ingénierie IT / Logiciel' },",
    "    { code: '64.19Z', label: 'Ingénierie Finance / Banque' },",
    "    { code: '72.19Z', label: 'Recherche & Développement' }",
    "];",
    "",
    "const getEffectifLabel = (code) => {",
    "    const map = {",
    "        '01': '1-2', '02': '3-5', '03': '6-9', '11': '10-19', '12': '20-49', ",
    "        '21': '50-99', '22': '100-199', '31': '200-249', '32': '250-499', ",
    "        '41': '500-999', '42': '1000-1999', '51': '2000-4999', '52': '5000-9999', '53': '10 000+'",
    "    };",
    "    return map[code] ? `${map[code]} salariés` : 'Effectif inconnu';",
    "};",
    "",
    "const radius = 50;",
    "let localOffices = [];",
    "",
    "for (const sector of sectors) {",
    "    try {",
    "        const url = `https://recherche-entreprises.api.gouv.fr/near_point?lat=${center.lat}&long=${center.lng}&radius=${radius}&activite_principale=${sector.code}&categorie_entreprise=GE&per_page=15`;",
    "        const response = await fetch(url);",
    "        const result = await response.json();",
    "        const companies = result.results || [];",
    "        const centerPoint = turf.point([center.lng, center.lat]);",
    "",
    "        for (const company of companies) {",
    "            if (company.matching_etablissements) {",
    "                for (const etab of company.matching_etablissements) {",
    "                    const effCode = etab.tranche_effectif_salarie;",
    "                    if (!effCode || ['NN', '00'].includes(effCode)) continue;",
    "",
    "                    const lat = parseFloat(etab.latitude);",
    "                    const lng = parseFloat(etab.longitude);",
    "                    if (!isNaN(lat) && !isNaN(lng)) {",
    "                        const distance = turf.distance(centerPoint, turf.point([lng, lat]), { units: 'kilometers' });",
    "                        if (distance <= radius) {",
    "                            localOffices.push({",
    "                                id: `off-${etab.siret}`,",
    "                                nom: company.nom_complet,",
    "                                context: sector.label,",
    "                                code: sector.code,",
    "                                siren: company.siren, siret: etab.siret, adresse: etab.adresse, ville: etab.libelle_commune,",
    "                                effectifs: getEffectifLabel(effCode), dirigeants: company.dirigeants || [],",
    "                                lat, lng, dist: distance.toFixed(1)",
    "                            });",
    "                        }",
    "                    }",
    "                }",
    "            }",
    "        }",
    "    } catch (e) { console.error(e); }",
    "}",
    "",
    "localOffices = Array.from(new Map(localOffices.map(o => [o.siret, o])).values());",
    "const uniqueSectorsFound = [...new Set(localOffices.map(o => `${o.code}|${o.context}`))];",
    "",
    "$context._analysisLayer = $context._analysisLayer || [];",
    "$context._officeMarkers = new Map();",
    "",
    "const clearLayer = () => {",
    "    for (const item of $context._analysisLayer) {",
    "        if ($map.getMapProvider() === 'GoogleMaps') item.setMap(null);",
    "        else item.remove();",
    "    }",
    "    $context._analysisLayer = [];",
    "    $context._officeMarkers.clear();",
    "};",
    "clearLayer();",
    "",
    "const html = `",
    "<div class=\"container-fluid p-0\">",
    "    <div class=\"card border-0 bg-dark text-white mb-2 shadow-sm\">",
    "        <div class=\"card-body p-2 d-flex justify-content-between align-items-center\">",
    "            <h6 class=\"m-0 font-weight-bold small\">SITES GE (50KM)</h6>",
    "            <button id=\"btn-fit\" class=\"btn btn-warning btn-sm py-0 px-2 font-weight-bold\" style=\"font-size: 0.7rem;\">",
    "                Ajuster la vue",
    "            </button>",
    "        </div>",
    "    </div>",
    "",
    "    <div class=\"mb-2 px-1\">",
    "        <select id=\"sector-filter\" class=\"form-control form-control-sm border-primary\" style=\"font-size: 0.8rem;\">",
    "            <option value=\"all\">Tous les secteurs (${localOffices.length})</option>",
    "            ${uniqueSectorsFound.map(s => {",
    "                const [code, label] = s.split('|');",
    "                return `<option value=\"${code}\">${label} (${code})</option>`;",
    "            }).join('')}",
    "        </select>",
    "    </div>",
    "",
    "    <div id=\"deep-detail\" class=\"card border-primary mb-2 d-none shadow-sm\">",
    "        <div class=\"card-body p-2\">",
    "            <div class=\"d-flex justify-content-between mb-1 align-items-center\">",
    "                <h6 id=\"d-name\" class=\"text-primary font-weight-bold m-0 small text-truncate\" style=\"max-width: 80%;\">-</h6>",
    "                <span class=\"badge badge-info\" style=\"font-size: 0.6rem;\">GE</span>",
    "            </div>",
    "            <div class=\"bg-light p-2 rounded mb-2 border-left border-primary\">",
    "                <div class=\"x-small text-dark font-weight-bold mb-1\">CONTEXTE : <span id=\"d-context\" class=\"text-primary\">-</span></div>",
    "                <div class=\"x-small text-muted\">ADRESSE : <span id=\"d-addr\">-</span></div>",
    "                <div class=\"x-small\">EFFECTIFS SITE : <span id=\"d-eff\" class=\"text-success font-weight-bold\">-</span></div>",
    "            </div>",
    "            <div class=\"border-top pt-1 d-flex justify-content-between x-small align-items-center\">",
    "                <span><b>DENSITÉ (200m) :</b></span>",
    "                <span id=\"d-density\" class=\"text-info font-weight-bold\">-</span>",
    "            </div>",
    "        </div>",
    "    </div>",
    "",
    "    <div class=\"table-responsive\" style=\"max-height: 18rem;\">",
    "        <table class=\"table table-sm table-hover\">",
    "            <thead class=\"thead-light x-small\">",
    "                <tr><th>Groupe / Activité</th><th class=\"text-right\">Distance</th></tr>",
    "            </thead>",
    "            <tbody id=\"office-table-body\" style=\"font-size: 0.75rem;\">",
    "                ${localOffices.map(o => `",
    "                    <tr style=\"cursor:pointer\" class=\"office-row\" id=\"row-${o.id}\" data-id=\"${o.id}\" data-sector=\"${o.code}\">",
    "                        <td class=\"py-2\">",
    "                            <div class=\"font-weight-bold text-truncate\" style=\"max-width: 170px;\">${o.nom}</div>",
    "                            <div class=\"x-small text-primary\">${o.context}</div>",
    "                            <div class=\"x-small text-muted\">${o.ville} • ${o.effectifs}</div>",
    "                        </td>",
    "                        <td class=\"text-right align-middle text-info font-weight-bold\">${o.dist}km</td>",
    "                    </tr>",
    "                `).join('')}",
    "            </tbody>",
    "        </table>",
    "    </div>",
    "</div>",
    "<style>.x-small { font-size: 0.68rem; } .table-warning { background-color: rgba(0, 123, 255, 0.1) !important; }</style>",
    "`;",
    "",
    "requestAnimationFrame(() => {",
    "    const detail = document.getElementById('deep-detail');",
    "    const dName = document.getElementById('d-name');",
    "    const dContext = document.getElementById('d-context');",
    "    const dAddr = document.getElementById('d-addr');",
    "    const dEff = document.getElementById('d-eff');",
    "    const dDens = document.getElementById('d-density');",
    "    const sectorFilter = document.getElementById('sector-filter');",
    "",
    "    const showOfficeDetails = async (o) => {",
    "        detail.classList.remove('d-none');",
    "        dName.innerText = o.nom; dContext.innerText = o.context; dAddr.innerText = o.adresse; dEff.innerText = o.effectifs;",
    "        $map.panTo({ lat: o.lat, lng: o.lng }); $map.setZoom(17);",
    "        document.querySelectorAll('.office-row').forEach(r => r.classList.remove('table-warning'));",
    "        const row = document.getElementById(`row-${o.id}`);",
    "        if (row) { row.classList.add('table-warning'); row.scrollIntoView({ behavior: 'smooth', block: 'nearest' }); }",
    "        dDens.innerText = 'Calcul...';",
    "        try {",
    "            const opUrl = `https://overpass-api.de/api/interpreter?data=[out:json];(node[\"office\"](around:200,${o.lat},${o.lng});way[\"office\"](around:200,${o.lat},${o.lng}););out count;`;",
    "            const opRes = await fetch(opUrl); const opData = await opRes.json();",
    "            const count = opData.elements[0]?.tags?.total || 0; dDens.innerHTML = `${count} bureaux voisins`;",
    "        } catch (e) { dDens.innerText = 'N/A'; }",
    "    };",
    "",
    "    // Création des marqueurs et stockage",
    "    for (const o of localOffices) {",
    "        const color = '#fd7e14';",
    "        let m;",
    "        if ($map.getMapProvider() === 'GoogleMaps') {",
    "            m = new google.maps.Marker({",
    "                position: { lat: o.lat, lng: o.lng },",
    "                map: $map.getMapObject(),",
    "                icon: { path: google.maps.SymbolPath.CIRCLE, scale: 9, fillColor: color, fillOpacity: 0.9, strokeWeight: 2, strokeColor: '#fff' }",
    "            });",
    "            m.addListener('click', () => showOfficeDetails(o));",
    "        } else {",
    "            m = L.circleMarker([o.lat, o.lng], {",
    "                radius: 9, fillColor: color, color: '#fff', weight: 2, opacity: 1, fillOpacity: 0.9",
    "            }).addTo($map.getMapObject());",
    "            m.on('click', () => showOfficeDetails(o));",
    "        }",
    "        $context._analysisLayer.push(m);",
    "        $context._officeMarkers.set(o.id, m);",
    "    }",
    "",
    "    // Logique de filtrage",
    "    sectorFilter.addEventListener('change', () => {",
    "        const selectedSector = sectorFilter.value;",
    "        ",
    "        localOffices.forEach(o => {",
    "            const isVisible = selectedSector === 'all' || o.code === selectedSector;",
    "            const marker = $context._officeMarkers.get(o.id);",
    "            const row = document.getElementById(`row-${o.id}`);",
    "",
    "            if (marker) {",
    "                if ($map.getMapProvider() === 'GoogleMaps') marker.setVisible(isVisible);",
    "                else isVisible ? marker.addTo($map.getMapObject()) : marker.remove();",
    "            }",
    "            if (row) isVisible ? row.classList.remove('d-none') : row.classList.add('d-none');",
    "        });",
    "    });",
    "",
    "    document.getElementById('btn-fit').addEventListener('click', () => {",
    "        const selectedSector = sectorFilter.value;",
    "        const visibleOffices = localOffices.filter(o => selectedSector === 'all' || o.code === selectedSector);",
    "        if (visibleOffices.length === 0) return;",
    "",
    "        if ($map.getMapProvider() === 'GoogleMaps') {",
    "            const bounds = new google.maps.LatLngBounds();",
    "            visibleOffices.forEach(o => bounds.extend({ lat: o.lat, lng: o.lng }));",
    "            $map.getMapObject().fitBounds(bounds);",
    "        } else {",
    "            const latlngs = visibleOffices.map(o => [o.lat, o.lng]);",
    "            $map.getMapObject().fitBounds(L.latLngBounds(latlngs));",
    "        }",
    "    });",
    "",
    "    document.querySelectorAll('.office-row').forEach(row => {",
    "        row.addEventListener('click', () => {",
    "            const office = localOffices.find(o => o.id === row.dataset.id);",
    "            if (office) showOfficeDetails(office);",
    "        });",
    "    });",
    "});",
    "",
    "return { html, data: localOffices, reset: clearLayer };"
  ],
  "description": "Analyse stratégique multisectorielle (Technique, IT, Finance, R&D) focalisée sur les bureaux locaux des grands groupes (GE). L'outil propose un filtrage dynamique par secteur d'activité, synchronisant la visibilité sur la carte et le tableau, avec accès aux effectifs et analyse de densité locale.",
  "title": "Ingénierie GE : Filtre par Secteur",
  "output": {
    "nom": "string",
    "context": "string",
    "code": "string",
    "adresse": "string",
    "effectifs": "string",
    "lat": "number",
    "lng": "number"
  },
  "mode": "SINGLE-POINT",
  "ownerId": "renaud.pawlak.dev481@agentforce.com",
  "tags": [ "france", "esn", "grands groupes", "ingénierie" ]
}