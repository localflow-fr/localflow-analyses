{
  "formula": [
    "const markers = $map.getSelectionIds().map(id => $map.getMarker(id));",
    "if (markers.length !== 1) {",
    "    return { html: '<div class=\"alert alert-warning\">Veuillez sélectionner exactement un point pour l\\'analyse.</div>' };",
    "}",
    "",
    "const sourceMarker = markers[0];",
    "let center = sourceMarker.latlng;",
    "if (!center) {",
    "    const bounds = $map.getMarkerBounds($map.getMarkerId(sourceMarker));",
    "    const centerPoint = bounds.getCenter();",
    "    center = typeof centerPoint.toJSON === 'function' ? centerPoint.toJSON() : centerPoint;",
    "}",
    "",
    "// Nettoyage des couches précédentes",
    "if ($context._analysisLayer) {",
    "    for (const obj of $context._analysisLayer) {",
    "        if (obj.setMap) obj.setMap(null);",
    "        else if (obj.remove) obj.remove();",
    "    }",
    "}",
    "$context._analysisLayer = [];",
    "",
    "const provider = $map.getMapProvider();",
    "const mapObj = $map.getMapObject();",
    "const radius = 200;",
    "const sourcePoint = turf.point([center.lng, center.lat]);",
    "",
    "// Helpers pour le dessin multi-provider",
    "const addCircle = (center, radius, options) => {",
    "    if (provider === 'GoogleMaps') {",
    "        const c = new google.maps.Circle({ ",
    "            center, radius, map: mapObj, ",
    "            strokeColor: options.color, strokeOpacity: 0.3, strokeWeight: 1, ",
    "            fillColor: options.color, fillOpacity: 0.05, clickable: false ",
    "        });",
    "        $map.fitBounds(c.getBounds());",
    "        return c;",
    "    } else {",
    "        const c = L.circle([center.lat, center.lng], { ",
    "            radius, color: options.color, weight: 1, opacity: 0.3, ",
    "            fillColor: options.color, fillOpacity: 0.05, interactive: false ",
    "        }).addTo(mapObj);",
    "        mapObj.fitBounds(c.getBounds());",
    "        return c;",
    "    }",
    "};",
    "",
    "const addPolygon = (coords, options) => {",
    "    if (provider === 'GoogleMaps') {",
    "        const paths = coords[0].map(c => ({ lng: c[0], lat: c[1] }));",
    "        return new google.maps.Polygon({",
    "            paths, map: mapObj, strokeColor: options.color, strokeOpacity: options.opacity || 0.8, ",
    "            strokeWeight: 1, fillColor: options.color, fillOpacity: options.fillOpacity || 0.4, zIndex: options.zIndex",
    "        });",
    "    } else {",
    "        const latlngs = coords[0].map(c => [c[1], c[0]]);",
    "        return L.polygon(latlngs, {",
    "            color: options.color, weight: 1, opacity: options.opacity || 0.8, ",
    "            fillColor: options.color, fillOpacity: options.fillOpacity || 0.4",
    "        }).addTo(mapObj);",
    "    }",
    "};",
    "",
    "const addLine = (p1, p2, options) => {",
    "    if (provider === 'GoogleMaps') {",
    "        return new google.maps.Polyline({",
    "            path: [p1, p2], map: mapObj, strokeColor: options.color, strokeOpacity: 0.5, strokeWeight: 1, zIndex: options.zIndex",
    "        });",
    "    } else {",
    "        return L.polyline([[p1.lat, p1.lng], [p2.lat, p2.lng]], {",
    "            color: options.color, weight: 1, opacity: 0.5",
    "        }).addTo(mapObj);",
    "    }",
    "};",
    "",
    "// 1. Cercle d'emprise",
    "$context._analysisLayer.push(addCircle(center, radius, { color: '#007bff' }));",
    "",
    "// 2. Catégories",
    "const categories = {",
    "    habitation: { label: 'Habitation', color: '#28a745', tags: ['house', 'apartments', 'residential', 'detached', 'terrace', 'dormitory', 'hotel'] },",
    "    commercial: { label: 'Commerce', color: '#007bff', tags: ['retail', 'commercial', 'office', 'supermarket', 'kiosk'] },",
    "    industrial: { label: 'Industrie', color: '#6f42c1', tags: ['industrial', 'warehouse', 'manufacture', 'factory'] },",
    "    public: { label: 'Public', color: '#ffc107', tags: ['school', 'university', 'hospital', 'church', 'civic', 'public', 'kindergarten', 'government'] }",
    "};",
    "",
    "const getCategory = (tag) => {",
    "    if (categories.commercial.tags.includes(tag)) return 'commercial';",
    "    if (categories.industrial.tags.includes(tag)) return 'industrial';",
    "    if (categories.public.tags.includes(tag)) return 'public';",
    "    return 'habitation'; ",
    "};",
    "",
    "// 3. Requête Overpass",
    "const overpassQuery = `[out:json][timeout:25];",
    "(",
    "  way[\"building\"](around:${radius},${center.lat},${center.lng});",
    "  way[\"landuse\"~\"forest|orchard|village_green\"](around:${radius},${center.lat},${center.lng});",
    "  way[\"natural\"~\"wood|scrub|tree_row\"](around:${radius},${center.lat},${center.lng});",
    "  way[\"leisure\"~\"park|garden\"](around:${radius},${center.lat},${center.lng});",
    ");",
    "out geom;`;",
    "",
    "try {",
    "    const resp = await fetch(`https://overpass-api.de/api/interpreter?data=${encodeURIComponent(overpassQuery)}`);",
    "    const osmData = await resp.json();",
    "",
    "    const buildingFeatures = [];",
    "    const vegetationFeatures = [];",
    "",
    "    for (const w of osmData.elements.filter(e => e.type === 'way' && e.geometry)) {",
    "        const coords = w.geometry.map(p => [p.lon, p.lat]);",
    "        if (coords[0][0] !== coords[coords.length-1][0] || coords[0][1] !== coords[coords.length-1][1]) coords.push(coords[0]);",
    "        if (coords.length > 3) {",
    "            const poly = turf.polygon([coords], { id: w.id, tags: w.tags || {} });",
    "            if (w.tags?.building) buildingFeatures.push(poly); else vegetationFeatures.push(poly);",
    "        }",
    "    }",
    "",
    "    let sourceBuildingId = null;",
    "    for (const building of buildingFeatures) {",
    "        if (turf.booleanPointInPolygon(sourcePoint, building)) {",
    "            sourceBuildingId = building.properties.id;",
    "            break;",
    "        }",
    "    }",
    "",
    "    // Dessin végétation",
    "    for (const veg of vegetationFeatures) {",
    "        $context._analysisLayer.push(addPolygon(veg.geometry.coordinates, { color: '#19692c', opacity: 0.5, fillOpacity: 0.2, zIndex: 1 }));",
    "    }",
    "",
    "    const stats = {};",
    "    Object.keys(categories).forEach(k => stats[k] = { total: 0, visible: 0, obstructed: 0 });",
    "",
    "    // 4. Calcul de co-visibilité",
    "    for (const building of buildingFeatures) {",
    "        const bType = getCategory(building.properties.tags.building);",
    "        const bCenter = turf.centroid(building);",
    "        const bCoords = bCenter.geometry.coordinates;",
    "        const losLine = turf.lineString([sourcePoint.geometry.coordinates, bCoords]);",
    "        ",
    "        let isObstructed = false;",
    "        for (const other of buildingFeatures) {",
    "            if (other.properties.id === building.properties.id || other.properties.id === sourceBuildingId) continue;",
    "            if (turf.lineIntersect(losLine, other).features.length > 0) { isObstructed = true; break; }",
    "        }",
    "        if (!isObstructed) {",
    "            for (const veg of vegetationFeatures) {",
    "                if (turf.lineIntersect(losLine, veg).features.length > 0) { isObstructed = true; break; }",
    "            }",
    "        }",
    "",
    "        stats[bType].total++;",
    "        if (isObstructed) stats[bType].obstructed++; else stats[bType].visible++;",
    "",
    "        $context._analysisLayer.push(addPolygon(building.geometry.coordinates, { color: categories[bType].color, zIndex: 2 }));",
    "        $context._analysisLayer.push(addLine(center, { lat: bCoords[1], lng: bCoords[0] }, { color: isObstructed ? '#dc3545' : '#28a745', zIndex: 3 }));",
    "    }",
    "",
    "    const chartId = 'chart-' + Math.random().toString(36).substr(2, 9);",
    "    requestAnimationFrame(() => {",
    "        const ctx = document.getElementById(chartId);",
    "        if (ctx) {",
    "            new Chart(ctx, {",
    "                type: 'bar', data: {",
    "                    labels: [''],",
    "                    datasets: Object.entries(categories).map(([key, cat]) => ({",
    "                        label: cat.label, data: [stats[key].total], backgroundColor: cat.color, barThickness: 22",
    "                    }))",
    "                },",
    "                options: {",
    "                    indexAxis: 'y', maintainAspectRatio: false,",
    "                    scales: { x: { stacked: true, display: false }, y: { stacked: true, display: false } },",
    "                    plugins: { legend: { display: false } }",
    "                }",
    "            });",
    "        }",
    "    });",
    "",
    "    return {",
    "        html: `",
    "            <div class=\"card border-0 shadow-sm\">",
    "                <div class=\"card-header bg-white py-2 font-weight-bold\">Analyse Voisinage (Rayon ${radius}m)</div>",
    "                <div class=\"card-body p-3\">",
    "                    ${sourceBuildingId ? '<div class=\"alert alert-info py-1 px-2 small mb-2\">Le point est situé sur un bâtiment : celui-ci est exclu des obstacles.</div>' : ''}",
    "                    <div class=\"mb-2 d-flex flex-wrap justify-content-center\">",
    "                        ${Object.values(categories).map(c => `<small class=\"mr-2 text-dark\"><span style=\"width:8px;height:8px;background:${c.color};display:inline-block;\" class=\"mr-1\"></span>${c.label}</small>`).join('')}",
    "                        <small class=\"text-dark\"><span style=\"width:8px;height:8px;background:#19692c;display:inline-block;\" class=\"mr-1\"></span>Végétation</small>",
    "                    </div>",
    "                    <div style=\"height: 30px;\" class=\"mb-3\"><canvas id=\"${chartId}\"></canvas></div>",
    "                    ",
    "                    <table class=\"table table-sm table-borderless mb-0\" style=\"font-size: 0.8rem;\">",
    "                        <thead class=\"text-muted border-bottom\">",
    "                            <tr>",
    "                                <th>Catégorie</th>",
    "                                <th class=\"text-center\">Total</th>",
    "                                <th class=\"text-center text-success\">Visible</th>",
    "                                <th class=\"text-center text-danger\">Obstrué</th>",
    "                            </tr>",
    "                        </thead>",
    "                        <tbody class=\"text-dark\">",
    "                            ${Object.entries(categories).map(([key, cat]) => `",
    "                                <tr>",
    "                                    <td class=\"font-weight-bold\" style=\"color:${cat.color}\">${cat.label}</td>",
    "                                    <td class=\"text-center font-weight-bold\">${stats[key].total}</td>",
    "                                    <td class=\"text-center\">${stats[key].visible}</td>",
    "                                    <td class=\"text-center\">${stats[key].obstructed}</td>",
    "                                </tr>",
    "                            `).join('')}",
    "                        </tbody>",
    "                    </table>",
    "                </div>",
    "                <div class=\"card-footer bg-light p-2 text-center small font-weight-bold\">",
    "                    TAUX DE VISIBILITÉ DIRECTE : ${Math.round((Object.values(stats).reduce((a,b)=>a+b.visible,0) / (buildingFeatures.length || 1)) * 100)}%",
    "                </div>",
    "            </div>",
    "        `,",
    "        data: stats,",
    "        reset: () => {",
    "            if ($context._analysisLayer) {",
    "                for (const o of $context._analysisLayer) {",
    "                    if (o.setMap) o.setMap(null);",
    "                    else if (o.remove) o.remove();",
    "                }",
    "            }",
    "        }",
    "    };",
    "} catch (e) {",
    "    console.error(e);",
    "    return { html: '<div class=\"alert alert-danger small\">Erreur lors de la récupération des données OSM.</div>' };",
    "}"
  ],
  "description": "This cartographic analysis identifies all buildings and vegetation areas within a 200-meter radius around a selected point. It then calculates the line of sight towards each neighboring building to determine whether it is visible or obstructed by other structures, providing an essential co-visibility indicator for impact studies or neighborhood assessments. Compatible with Google Maps and Leaflet.",
  "title": "Neighborhood & Co-Visibility Analysis",
  "output": {
    "habitation": {
      "total": "number",
      "visible": "number",
      "obstructed": "number"
    },
    "commercial": {
      "total": "number",
      "visible": "number",
      "obstructed": "number"
    },
    "industrial": {
      "total": "number",
      "visible": "number",
      "obstructed": "number"
    },
    "public": {
      "total": "number",
      "visible": "number",
      "obstructed": "number"
    }
  },
  "tags": [ "world", "visibility", "line-of-sight", "urban", "cartography" ]
}