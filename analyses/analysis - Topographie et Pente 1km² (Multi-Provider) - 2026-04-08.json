{
  "formula": [
    "const selection = $map.getSelectionIds();",
    "if (selection.length !== 1) return { html: \"Sélectionnez un point unique pour démarrer l'analyse topographique.\" };",
    "",
    "const marker = $map.getMarker(selection[0]);",
    "const center = marker.latlng || $map.getMarkerBounds($map.getMarkerId(marker)).getCenter().toJSON();",
    "const provider = $map.getMapProvider();",
    "const isGoogle = provider === 'GoogleMaps';",
    "const mapObj = $map.getMapObject();",
    "",
    "// 1. Grille 21x21 et Altitudes (Emprise 1km²)",
    "const dist = 0.5;",
    "const centerPt = turf.point([center.lng, center.lat]);",
    "const bbox = turf.bbox(turf.buffer(centerPt, dist, { units: 'kilometers' }));",
    "const square = turf.bboxPolygon(bbox);",
    "const latStep = (bbox[3] - bbox[1]) / 20, lngStep = (bbox[2] - bbox[0]) / 20;",
    "",
    "const gridFeatures = [];",
    "for (let r = 0; r <= 20; r++) {",
    "    const lat = bbox[3] - (r * latStep);",
    "    for (let c = 0; c <= 20; c++) {",
    "        const lng = bbox[0] + (c * lngStep);",
    "        gridFeatures.push(turf.point([lng, lat]));",
    "    }",
    "}",
    "const grid = turf.featureCollection(gridFeatures);",
    "",
    "console.info('Fetching elevation data...');",
    "let elevations = [];",
    "for (let i = 0; i < grid.features.length; i += 50) {",
    "    const b = grid.features.slice(i, i + 50);",
    "    const url = `https://api.open-meteo.com/v1/elevation?latitude=${b.map(f => f.geometry.coordinates[1]).join(',')}&longitude=${b.map(f => f.geometry.coordinates[0]).join(',')}`;",
    "    const res = await fetch(url);",
    "    const d = await res.json();",
    "    elevations = elevations.concat(d.elevation);",
    "}",
    "grid.features.forEach((f, i) => f.properties.elevation = elevations[i]);",
    "",
    "const matrix = [];",
    "for (let i = 0; i < 21; i++) matrix.push(grid.features.slice(i * 21, (i + 1) * 21));",
    "",
    "const refRes = await fetch(`https://api.open-meteo.com/v1/elevation?latitude=${center.lat}&longitude=${center.lng}`);",
    "const refData = await refRes.json();",
    "const refAlt = refData.elevation[0];",
    "",
    "// 2. Calcul des pentes",
    "const getSlopeAt = (r, c) => {",
    "    let maxS = 0;",
    "    const h0 = matrix[r][c].properties.elevation;",
    "    for (let dr = -1; dr <= 1; dr++) {",
    "        for (let dc = -1; dc <= 1; dc++) {",
    "            if (dr === 0 && dc === 0) continue;",
    "            const nr = r + dr, nc = c + dc;",
    "            if (nr >= 0 && nr <= 20 && nc >= 0 && nc <= 20) {",
    "                const dM = (dr !== 0 && dc !== 0) ? 50 * Math.sqrt(2) : 50;",
    "                const s = (Math.abs(matrix[nr][nc].properties.elevation - h0) / dM) * 100;",
    "                if (s > maxS) maxS = s;",
    "            }",
    "        }",
    "    }",
    "    return maxS;",
    "};",
    "",
    "let allSlopes = [];",
    "for (let r = 0; r <= 20; r++) {",
    "    for (let c = 0; c <= 20; c++) allSlopes.push(getSlopeAt(r, c));",
    "}",
    "const gMaxSlope = Math.max(...allSlopes);",
    "const getSlopeColor = (v) => v < 5 ? '#2ecc71' : v < 12 ? '#f39c12' : '#e74c3c';",
    "",
    "// 3. Dessin Carte (Compatible Multi-Provider)",
    "if (!window._analysisLayer) window._analysisLayer = [];",
    "const clear = () => {",
    "    window._analysisLayer.forEach(l => {",
    "        if (isGoogle) l.setMap(null);",
    "        else l.remove();",
    "    });",
    "    window._analysisLayer = [];",
    "};",
    "clear();",
    "",
    "const minE = Math.min(...elevations), maxE = Math.max(...elevations);",
    "const breaks = Array.from({length: Math.max(2, Math.ceil(maxE - minE))}, (_, i) => Math.floor(minE) + i);",
    "",
    "const lerp = (a, b, t) => {",
    "    const ah = parseInt(a.slice(1), 16), bh = parseInt(b.slice(1), 16);",
    "    const r = (ah >> 16) + t * ((bh >> 16) - (ah >> 16)), g = (ah >> 8 & 0xff) + t * ((bh >> 8 & 0xff) - (ah >> 8 & 0xff)), bl = (ah & 0xff) + t * ((bh & 0xff) - (ah & 0xff));",
    "    return '#' + ((1 << 24) + (Math.round(r) << 16) + (Math.round(g) << 8) + Math.round(bl)).toString(16).slice(1);",
    "};",
    "",
    "// Isobands",
    "turf.isobands(grid, breaks, { zProperty: 'elevation' }).features.forEach(f => {",
    "    const alt = parseFloat(f.properties.elevation.split('-')[0]);",
    "    const color = alt < refAlt ? lerp('#2ecc71', '#ffffff', (alt - minE) / (refAlt - minE || 1)) : lerp('#ffffff', '#e74c3c', (alt - refAlt) / (maxE - refAlt || 1));",
    "    ",
    "    f.geometry.coordinates.forEach(poly => {",
    "        if (isGoogle) {",
    "            const p = new google.maps.Polygon({ paths: poly.map(r => r.map(c => ({ lat: c[1], lng: c[0] }))), strokeWeight: 0, fillOpacity: 0.35, fillColor: color, map: mapObj, clickable: false });",
    "            window._analysisLayer.push(p);",
    "        } else {",
    "            const p = L.polygon(poly.map(r => r.map(c => [c[1], c[0]])), { stroke: false, fillOpacity: 0.35, fillColor: color, interactive: false }).addTo(mapObj);",
    "            window._analysisLayer.push(p);",
    "        }",
    "    });",
    "});",
    "",
    "// Isolines",
    "turf.isolines(grid, breaks, { zProperty: 'elevation' }).features.forEach(f => {",
    "    f.geometry.coordinates.forEach(ring => {",
    "        if (isGoogle) {",
    "            const l = new google.maps.Polyline({ path: ring.map(c => ({ lat: c[1], lng: c[0] })), strokeColor: '#2c3e50', strokeOpacity: 0.2, strokeWeight: 0.9, map: mapObj, clickable: false });",
    "            window._analysisLayer.push(l);",
    "        } else {",
    "            const l = L.polyline(ring.map(c => [c[1], c[0]]), { color: '#2c3e50', opacity: 0.2, weight: 1, interactive: false }).addTo(mapObj);",
    "            window._analysisLayer.push(l);",
    "        }",
    "    });",
    "});",
    "",
    "// UI Elements (Interactive square and lines)",
    "let analysisSquare, lineNS, lineEW, markerPt;",
    "",
    "if (isGoogle) {",
    "    analysisSquare = new google.maps.Polygon({ path: square.geometry.coordinates[0].map(c => ({ lat: c[1], lng: c[0] })), strokeColor: '#2c3e50', strokeWeight: 2, fillOpacity: 0, map: mapObj, zIndex: 100 });",
    "    lineNS = new google.maps.Polyline({ strokeColor: '#34495e', strokeWeight: 1, map: mapObj, zIndex: 101 });",
    "    lineEW = new google.maps.Polyline({ strokeColor: '#34495e', strokeWeight: 1, map: mapObj, zIndex: 101 });",
    "    markerPt = new google.maps.Marker({ icon: { path: google.maps.SymbolPath.CIRCLE, fillColor: '#ff0000', fillOpacity: 1, strokeWeight: 2, strokeColor: '#fff', scale: 7 }, map: mapObj, zIndex: 102, clickable: false });",
    "} else {",
    "    analysisSquare = L.polygon(square.geometry.coordinates[0].map(c => [c[1], c[0]]), { color: '#2c3e50', weight: 2, fillOpacity: 0 }).addTo(mapObj);",
    "    lineNS = L.polyline([[0,0],[0,0]], { color: '#34495e', weight: 1 }).addTo(mapObj);",
    "    lineEW = L.polyline([[0,0],[0,0]], { color: '#34495e', weight: 1 }).addTo(mapObj);",
    "    markerPt = L.circleMarker([0,0], { radius: 7, color: '#fff', weight: 2, fillColor: '#ff0000', fillOpacity: 1 }).addTo(mapObj);",
    "}",
    "window._analysisLayer.push(analysisSquare, lineNS, lineEW, markerPt);",
    "",
    "// 4. UI",
    "const cid1 = 'c-ew-' + Date.now(), cid2 = 'c-ns-' + Date.now();",
    "const html = `",
    "<div class=\"card border-0 shadow-sm\">",
    "    <div class=\"card-body p-2\">",
    "        <div class=\"topo-legend mb-2 px-2\">",
    "            <div class=\"d-flex justify-content-between small text-muted mb-1\">",
    "                <span>Alt. Min: <strong>${Math.round(minE)}m</strong></span>",
    "                <span class=\"font-weight-bold text-dark\">Zéro Centre: ${Math.round(refAlt)}m</span>",
    "                <span>Alt. Max: <strong>${Math.round(maxE)}m</strong></span>",
    "            </div>",
    "            <div style=\"height: 8px; border-radius: 4px; background: linear-gradient(to right, #2ecc71, #ffffff, #e74c3c); border: 1px solid #ddd;\"></div>",
    "            <div class=\"mt-2 small text-muted font-weight-bold text-center\">Pente Max Zone: <span class=\"badge badge-danger\">${gMaxSlope.toFixed(1)}%</span></div>",
    "        </div>",
    "        <div id=\"info-card\" class=\"alert alert-light border shadow-sm py-2 mb-3\"></div>",
    "        <div class=\"row no-gutters\">",
    "            <div class=\"col-6 pr-1 border-right\">",
    "                <div class=\"small font-weight-bold text-center mb-1 text-muted uppercase\">AXE E-O</div>",
    "                <div style=\"height: 15rem;\"><canvas id=\"${cid1}\"></canvas></div>",
    "            </div>",
    "            <div class=\"col-6 pl-1\">",
    "                <div class=\"small font-weight-bold text-center mb-1 text-muted uppercase\">AXE N-S</div>",
    "                <div style=\"height: 15rem;\"><canvas id=\"${cid2}\"></canvas></div>",
    "            </div>",
    "        </div>",
    "    </div>",
    "</div>`;",
    "",
    "requestAnimationFrame(() => {",
    "    const labels = Array.from({length: 21}, (_, i) => (i - 10) * 50);",
    "    const yLimit = Math.max(Math.abs(minE - refAlt), Math.abs(maxE - refAlt)) + 10;",
    "    let currentR = 10, currentC = 10;",
    "",
    "    const createChart = (ctx, isEW) => new Chart(ctx, {",
    "        type: 'line',",
    "        data: {",
    "            labels: labels,",
    "            datasets: [",
    "                { label: 'Relief', data: [], borderColor: '#000', borderWidth: 2, fill: false, tension: 0, pointRadius: 3, pointBackgroundColor: '#000', order: 3 },",
    "                { label: 'Réf', data: labels.map(() => 0), borderColor: '#888', borderDash: [4, 4], fill: false, pointRadius: 0, order: 1, borderWidth: 1 },",
    "                { label: 'Point', data: [], borderColor: '#ff0000', fill: false, pointRadius: 8, pointBackgroundColor: '#ff0000', pointBorderColor: '#fff', showLine: false, order: 0 }",
    "            ]",
    "        },",
    "        options: {",
    "            responsive: true, maintainAspectRatio: false, animation: false, ",
    "            plugins: { legend: { display: false }, tooltip: { enabled: false } },",
    "            scales: { y: { min: -yLimit, max: yLimit, ticks: { callback: v => Math.round(v) + 'm' } }, x: { ticks: { callback: (v, i) => labels[i] + 'm' } } },",
    "            onClick: (e, items) => {",
    "                if (items.length > 0) {",
    "                    const idx = items[0].index;",
    "                    const pt = isEW ? matrix[currentR][idx] : matrix[20 - idx][currentC];",
    "                    update(pt.geometry.coordinates[1], pt.geometry.coordinates[0]);",
    "                }",
    "            }",
    "        }",
    "    });",
    "",
    "    const chartEW = createChart(document.getElementById(cid1), true);",
    "    const chartNS = createChart(document.getElementById(cid2), false);",
    "    const info = document.getElementById('info-card');",
    "",
    "    const update = (lat, lng) => {",
    "        const cIdx = Math.min(20, Math.max(0, Math.round(((lng - bbox[0]) / (bbox[2] - bbox[0])) * 20)));",
    "        const rIdx = Math.min(20, Math.max(0, Math.round(((bbox[3] - lat) / (bbox[3] - bbox[1])) * 20)));",
    "        currentR = rIdx; currentC = cIdx;",
    "",
    "        const dX = (cIdx - 10) * 50, dY = (10 - rIdx) * 50, pt = matrix[rIdx][cIdx], relAlt = Math.round(pt.properties.elevation - refAlt);",
    "        const sVal = getSlopeAt(rIdx, cIdx);",
    "",
    "        info.innerHTML = `",
    "            <div class=\"row text-center small align-items-center\">",
    "                <div class=\"col-4 border-right\"><strong>Alt: ${Math.round(pt.properties.elevation)}m</strong> (${relAlt >= 0 ? '+' : ''}${relAlt}m)</div>",
    "                <div class=\"col-4 border-right\"><strong>Pente:</strong> ${sVal.toFixed(1)}% <span style=\"color:${getSlopeColor(sVal)}; font-size: 1.2rem;\">●</span></div>",
    "                <div class=\"col-4\"><strong>Pos:</strong> ΔX:${dX}m | ΔY:${dY}m</div>",
    "            </div>`;",
    "        ",
    "        if (isGoogle) {",
    "            markerPt.setPosition({lat, lng});",
    "            lineNS.setPath([{ lat: bbox[3], lng: lng }, { lat: bbox[1], lng: lng }]);",
    "            lineEW.setPath([{ lat: lat, lng: bbox[0] }, { lat: lat, lng: bbox[2] }]);",
    "        } else {",
    "            markerPt.setLatLng([lat, lng]);",
    "            lineNS.setLatLngs([[bbox[3], lng], [bbox[1], lng]]);",
    "            lineEW.setLatLngs([[lat, bbox[0]], [lat, bbox[2]]]);",
    "        }",
    "",
    "        chartEW.data.datasets[0].data = matrix[rIdx].map(f => Math.round(f.properties.elevation - refAlt));",
    "        chartEW.data.datasets[2].data = labels.map((v, i) => i === cIdx ? relAlt : null);",
    "        chartEW.update();",
    "",
    "        const nsIdxOnGraph = 20 - rIdx;",
    "        chartNS.data.datasets[0].data = matrix.map(r => Math.round(r[cIdx].properties.elevation - refAlt)).reverse();",
    "        chartNS.data.datasets[2].data = labels.map((v, i) => i === nsIdxOnGraph ? relAlt : null);",
    "        chartNS.update();",
    "    };",
    "",
    "    update(center.lat, center.lng);",
    "",
    "    if (isGoogle) {",
    "        analysisSquare.addListener('click', (e) => update(e.latLng.lat(), e.latLng.lng()));",
    "    } else {",
    "        analysisSquare.on('click', (e) => update(e.latlng.lat, e.latlng.lng));",
    "    }",
    "});",
    "",
    "return { html, data: { refAlt, gMaxSlope }, reset: clear };"
  ],
  "description": "Topographical analysis of a 1km² area. Includes contour lines every meter, synchronized cross-section graphs with a real metric scale, and indicators of maximum slope.",
  "title": "Topographical Analysis & Slope (1km²)",
  "output": {
    "refAlt": "number",
    "gMaxSlope": "number"
  },
  "tags": [ "world", "topography", "slope", "isobands", "isoclines" ]
}