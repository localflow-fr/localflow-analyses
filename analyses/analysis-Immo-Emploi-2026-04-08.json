{
  "formula": [
    "const selectionIds = $map.getSelectionIds();",
    "if (selectionIds.length === 0) throw new Error(\"Sélectionnez un point de départ.\");",
    "const startMarker = $map.getMarker(selectionIds[0]);",
    "const startPos = startMarker.latlng || $map.getMarkerBounds(selectionIds[0]).getCenter().toJSON();",
    "",
    "$context._analysisLayer = $context._analysisLayer || [];",
    "const clearLayers = () => {",
    "    $context._analysisLayer.forEach(l => l.setMap ? l.setMap(null) : l.remove());",
    "    $context._analysisLayer = [];",
    "};",
    "",
    "const getPriceColor = (price) => {",
    "    if (!price) return 'transparent';",
    "    if (price < 3000) return '#2ecc71';",
    "    if (price < 4500) return '#f1c40f';",
    "    if (price < 6000) return '#e67e22';",
    "    return '#e74c3c';",
    "};",
    "",
    "const updateAnalysis = async (seconds) => {",
    "    const jobContainer = document.getElementById('job-list-opti');",
    "    const priceInfo = document.getElementById('price-avg-opti');",
    "    if (jobContainer) jobContainer.innerHTML = '<tr><td colspan=\"2\" class=\"text-center p-3\"><div class=\"spinner-border spinner-border-sm text-primary\"></div> Optimisation en cours...</td></tr>';",
    "    ",
    "    clearLayers();",
    "",
    "    try {",
    "        // 1. Isochrone",
    "        const isoRes = await fetch(`https://data.geopf.fr/navigation/isochrone?point=${startPos.lng},${startPos.lat}&resource=bdtopo-valhalla&costType=time&costValue=${seconds}&timeUnit=second&profile=car&direction=departure`);",
    "        const isoData = await isoRes.json();",
    "        const polygon = isoData.geometry;",
    "        const bbox = turf.bbox(polygon);",
    "        const flattenedIso = turf.flatten(polygon);",
    "",
    "        // 2. Emplois",
    "        const inseeRes = await fetch(`https://geo.api.gouv.fr/communes?lat=${startPos.lat}&lon=${startPos.lng}&fields=code`);",
    "        const inseeData = await inseeRes.json();",
    "        const inseeCode = inseeData[0]?.code || \"75056\";",
    "        const ftRadius = seconds > 1800 ? 50 : 25;",
    "        const ftRes = await fetch(`https://api.francetravail.io/partenaire/offresdemploi/v2/offres/search?commune=${inseeCode}&distance=${ftRadius}&range=0-49`);",
    "        let jobs = [];",
    "        if (ftRes.ok) {",
    "            const ftData = await ftRes.json();",
    "            jobs = (ftData.resultats || []).filter(j => {",
    "                if (!j.lieuTravail?.latitude) return false;",
    "                const pt = turf.point([parseFloat(j.lieuTravail.longitude), parseFloat(j.lieuTravail.latitude)]);",
    "                return flattenedIso.features.some(f => turf.booleanPointInPolygon(pt, f));",
    "            });",
    "        }",
    "",
    "        // 3. Collecte Optimisée DVF (Grille 4x4 pour alimenter 8x8)",
    "        const expBbox = [ bbox[0]-0.05, bbox[1]-0.05, bbox[2]+0.05, bbox[3]+0.05 ];",
    "        const fetchRes = 4; ",
    "        const gridRes = 8;",
    "        const allFeatures = [];",
    "",
    "        for (let i=0; i<fetchRes; i++) {",
    "            for (let j=0; j<fetchRes; j++) {",
    "                const fLat = expBbox[1] + ((expBbox[3]-expBbox[1])/fetchRes)*(i+0.5);",
    "                const fLng = expBbox[0] + ((expBbox[2]-expBbox[0])/fetchRes)*(j+0.5);",
    "                try {",
    "                    const dRes = await fetch(`https://gis.daquota.io/dvf?lat=${fLat}&lon=${fLng}&dist=5000`);",
    "                    const dData = await dRes.json();",
    "                    if (dData.features) allFeatures.push(...dData.features);",
    "                } catch(e) {}",
    "            }",
    "        }",
    "",
    "        // 4. Calcul de la grille 8x8",
    "        const grid = Array(gridRes).fill().map(() => Array(gridRes).fill(null).map(() => ({ sum: 0, count: 0, avg: null })));",
    "        const latStep = (expBbox[3]-expBbox[1])/gridRes;",
    "        const lngStep = (expBbox[2]-expBbox[0])/gridRes;",
    "",
    "        allFeatures.forEach(f => {",
    "            const [lon, lat] = f.geometry.coordinates;",
    "            if (f.properties.valeur_fonciere && f.properties.surface_reelle_bati > 0) {",
    "                const row = Math.floor((lat - expBbox[1]) / latStep);",
    "                const col = Math.floor((lon - expBbox[0]) / lngStep);",
    "                if (row >= 0 && row < gridRes && col >= 0 && col < gridRes) {",
    "                    grid[row][col].sum += (f.properties.valeur_fonciere / f.properties.surface_reelle_bati);",
    "                    grid[row][col].count++;",
    "                }",
    "            }",
    "        });",
    "",
    "        // Interpolation simple pour les cases vides",
    "        for (let r=0; r<gridRes; r++) {",
    "            for (let c=0; c<gridRes; c++) {",
    "                if (grid[r][c].count > 0) {",
    "                    grid[r][c].avg = grid[r][c].sum / grid[r][c].count;",
    "                } else {",
    "                    // Moyenne des voisins directs",
    "                    let nSum = 0, nCount = 0;",
    "                    for (let dr=-1; dr<=1; dr++) {",
    "                        for (let dc=-1; dc<=1; dc++) {",
    "                            const nr = r+dr, nc = c+dc;",
    "                            if (nr>=0 && nr<gridRes && nc>=0 && nc<gridRes && grid[nr][nc].count > 0) {",
    "                                nSum += (grid[nr][nc].sum / grid[nr][nc].count);",
    "                                nCount++;",
    "                            }",
    "                        }",
    "                    }",
    "                    if (nCount > 0) grid[r][c].avg = nSum / nCount;",
    "                }",
    "            }",
    "        }",
    "",
    "        // 5. Rendu Carte",
    "        const mapObj = $map.getMapObject();",
    "        const provider = $map.getMapProvider();",
    "",
    "        grid.forEach((row, r) => {",
    "            row.forEach((cell, c) => {",
    "                if (!cell.avg) return;",
    "                const coords = [",
    "                    [expBbox[0] + c*lngStep, expBbox[1] + r*latStep],",
    "                    [expBbox[0] + (c+1)*lngStep, expBbox[1] + r*latStep],",
    "                    [expBbox[0] + (c+1)*lngStep, expBbox[1] + (r+1)*latStep],",
    "                    [expBbox[0] + c*lngStep, expBbox[1] + (r+1)*latStep],",
    "                    [expBbox[0] + c*lngStep, expBbox[1] + r*latStep]",
    "                ];",
    "                if (provider === 'Leaflet') {",
    "                    const poly = L.polygon(coords.map(pt => [pt[1], pt[0]]), { color: 'white', weight: 0.2, fillColor: getPriceColor(cell.avg), fillOpacity: 0.4 }).addTo(mapObj);",
    "                    $context._analysisLayer.push(poly);",
    "                } else {",
    "                    const poly = new google.maps.Polygon({ paths: coords.map(pt => ({lat: pt[1], lng: pt[0]})), strokeColor: 'white', strokeWeight: 0.2, fillColor: getPriceColor(cell.avg), fillOpacity: 0.4, map: mapObj });",
    "                    $context._analysisLayer.push(poly);",
    "                }",
    "            });",
    "        });",
    "",
    "        // Isochrone & Emplois (priorité visuelle)",
    "        if (provider === 'Leaflet') {",
    "            const iso = L.geoJSON(polygon, { style: { color: '#007bff', weight: 3, fillOpacity: 0, dashArray: '5,10' } }).addTo(mapObj);",
    "            $context._analysisLayer.push(iso);",
    "            mapObj.fitBounds(iso.getBounds());",
    "            jobs.forEach(j => {",
    "                const m = L.circleMarker([j.lieuTravail.latitude, j.lieuTravail.longitude], { radius: 4, color: 'white', weight: 1, fillColor: '#e74c3c', fillOpacity: 1 }).addTo(mapObj);",
    "                $context._analysisLayer.push(m);",
    "            });",
    "        } else {",
    "            const iso = new google.maps.Polygon({ paths: polygon.coordinates[0].map(p => ({lat:p[1], lng:p[0]})), strokeColor: '#007bff', strokeWeight: 3, fillOpacity: 0, map: mapObj });",
    "            $context._analysisLayer.push(iso);",
    "            jobs.forEach(j => {",
    "                const m = new google.maps.Marker({ position: {lat: parseFloat(j.lieuTravail.latitude), lng: parseFloat(j.lieuTravail.longitude)}, icon: { path: google.maps.SymbolPath.CIRCLE, scale: 4, fillColor: '#e74c3c', fillOpacity: 1, strokeColor: 'white', strokeWeight: 1 }, map: mapObj });",
    "                $context._analysisLayer.push(m);",
    "            });",
    "        }",
    "",
    "        // 6. UI Update",
    "        if (jobContainer) jobContainer.innerHTML = jobs.length > 0 ? jobs.map(j => `<tr><td><small><strong>${j.intitule}</strong></small></td><td class=\"text-right\"><span class=\"badge badge-light\">${j.lieuTravail.libelle.split(' - ')[1] || ''}</span></td></tr>`).join('') : '<tr><td colspan=\"2\" class=\"text-center small\">Aucune offre.</td></tr>';",
    "        if (priceInfo) {",
    "            const totalAvg = grid.flat().filter(c => c.avg).reduce((acc, c) => acc + c.avg, 0) / grid.flat().filter(c => c.avg).length;",
    "            priceInfo.innerText = Math.round(totalAvg) + ' €/m² (moyenne zone)';",
    "        }",
    "",
    "    } catch (e) {",
    "        console.error(e);",
    "        if (jobContainer) jobContainer.innerHTML = `<tr><td class=\"text-danger\">Erreur: ${e.message}</td></tr>`;",
    "    }",
    "};",
    "",
    "const html = `",
    "<div class=\"card border-0 shadow-sm\">",
    "    <div class=\"card-body p-2\">",
    "        <div class=\"mb-2 p-2 bg-light border rounded\">",
    "            <div class=\"d-flex justify-content-between small mb-1\"><strong>Légende Prix au m²</strong><span id=\"price-avg-opti\" class=\"text-primary font-weight-bold\"></span></div>",
    "            <div class=\"d-flex\">",
    "                <div class=\"flex-fill text-center p-1\" style=\"background:#2ecc71; color:white; font-size:10px\">&lt;3k€</div>",
    "                <div class=\"flex-fill text-center p-1\" style=\"background:#f1c40f; color:black; font-size:10px\">3-4.5k€</div>",
    "                <div class=\"flex-fill text-center p-1\" style=\"background:#e67e22; color:white; font-size:10px\">4.5-6k€</div>",
    "                <div class=\"flex-fill text-center p-1\" style=\"background:#e74c3c; color:white; font-size:10px\">&gt;6k€</div>",
    "            </div>",
    "        </div>",
    "        <select id=\"iso-duration-opti\" class=\"form-control form-control-sm mb-2\">",
    "            <option value=\"1800\">30 minutes (Voiture)</option>",
    "            <option value=\"3600\">1 heure (Voiture)</option>",
    "        </select>",
    "        <div class=\"table-responsive\" style=\"max-height: 180px;\">",
    "            <table class=\"table table-sm table-hover mb-0\">",
    "                <tbody id=\"job-list-opti\"></tbody>",
    "            </table>",
    "        </div>",
    "    </div>",
    "</div>`;",
    "",
    "requestAnimationFrame(() => {",
    "    const select = document.getElementById('iso-duration-opti');",
    "    if (select) select.addEventListener('change', (e) => updateAnalysis(parseInt(e.target.value)));",
    "    updateAnalysis(1800);",
    "});",
    "",
    "return { html, data: { optimization: \"grid_interpolation\" }, reset: clearLayers };"
  ],
  "title": "Analyse Emploi",
  "description": "Cette analyse montre les emplois accessibles en voiture depuis un point de départ sélectionné, ainsi qu'une estimation du prix au m² dans la zone d'accessibilité.",
  "output": "{ optimization: string }",
  "mode": "SINGLE-POINT",
  "ownerId": "renaud.pawlak.dev481@agentforce.com",
  "tags": [ "france", "esn", "emploi", "isochrone", "dvf", "francetravail", "interpolation" ]
}