{
  "formula": [
    "const selectionIds = $map.getSelectionIds();",
    "if (selectionIds.length === 0) {",
    "    return {",
    "        html: '<div class=\"alert alert-warning small\">Veuillez sélectionner un point de référence sur la carte.</div>',",
    "        data: [],",
    "        reset: () => {}",
    "    };",
    "}",
    "",
    "const centerMarker = $map.getMarker(selectionIds[0]);",
    "let center = centerMarker.latlng;",
    "if (!center) {",
    "    const bounds = $map.getMarkerBounds(selectionIds[0]);",
    "    center = bounds.getCenter().toJSON ? bounds.getCenter().toJSON() : bounds.getCenter();",
    "}",
    "",
    "// Nettoyage",
    "if (!$context._analysisLayer) $context._analysisLayer = [];",
    "const clearLayer = () => {",
    "    $context._analysisLayer.forEach(item => {",
    "        if (item.setMap) item.setMap(null);",
    "        else if (item.remove) item.remove();",
    "    });",
    "    $context._analysisLayer = [];",
    "};",
    "clearLayer();",
    "",
    "const provider = $map.getMapProvider();",
    "const mapObj = $map.getMapObject();",
    "const RADIUS_KM = 50;",
    "",
    "// Dessin du cercle de contrôle",
    "const circle = turf.circle([center.lng, center.lat], RADIUS_KM, { units: 'kilometers' });",
    "if (provider === 'GoogleMaps') {",
    "    const coords = circle.geometry.coordinates[0].map(c => ({ lat: c[1], lng: c[0] }));",
    "    const poly = new google.maps.Polygon({",
    "        paths: coords, strokeColor: '#28a745', strokeOpacity: 0.8, strokeWeight: 2, fillColor: '#28a745', fillOpacity: 0.05, map: mapObj",
    "    });",
    "    $context._analysisLayer.push(poly);",
    "} else {",
    "    const geojson = L.geoJSON(circle, { style: { color: '#28a745', weight: 2, fillOpacity: 0.05 } }).addTo(mapObj);",
    "    $context._analysisLayer.push(geojson);",
    "}",
    "",
    "let establishmentsInRadius = [];",
    "",
    "try {",
    "    // On récupère les 2 premières pages pour avoir un échantillon significatif",
    "    for (let page = 1; page <= 2; page++) {",
    "        const url = `https://recherche-entreprises.api.gouv.fr/near_point?lat=${center.lat}&long=${center.lng}&radius=${RADIUS_KM}&per_page=25&page=${page}`;",
    "        const response = await fetch(url);",
    "        const result = await response.json();",
    "",
    "        if (!result.results) break;",
    "",
    "        for (const company of result.results) {",
    "            // On itère sur les établissements qui matchent la recherche géographique",
    "            if (!company.matching_etablissements) continue;",
    "",
    "            for (const etab of company.matching_etablissements) {",
    "                const lat = parseFloat(etab.latitude);",
    "                const lng = parseFloat(etab.longitude);",
    "                if (isNaN(lat) || isNaN(lng)) continue;",
    "",
    "                const dist = turf.distance(",
    "                    turf.point([center.lng, center.lat]),",
    "                    turf.point([lng, lat]),",
    "                    { units: 'kilometers' }",
    "                );",
    "",
    "                if (dist <= RADIUS_KM) {",
    "                    establishmentsInRadius.push({",
    "                        nom: company.nom_complet,",
    "                        enseigne: etab.liste_enseignes ? etab.liste_enseignes[0] : company.nom_complet,",
    "                        ville: etab.libelle_commune,",
    "                        cp: etab.code_postal,",
    "                        distance: dist,",
    "                        lat, lng,",
    "                        naf: etab.activite_principale",
    "                    });",
    "",
    "                    // Ajout du marqueur sur la carte",
    "                    if (provider === 'GoogleMaps') {",
    "                        const m = new google.maps.Marker({",
    "                            position: { lat, lng },",
    "                            map: mapObj,",
    "                            icon: { path: google.maps.SymbolPath.CIRCLE, fillColor: '#28a745', fillOpacity: 0.9, scale: 4, strokeColor: 'white', strokeWeight: 1 }",
    "                        });",
    "                        $context._analysisLayer.push(m);",
    "                    } else {",
    "                        const m = L.circleMarker([lat, lng], { radius: 4, fillColor: '#28a745', color: '#fff', weight: 1, fillOpacity: 0.9 }).addTo(mapObj);",
    "                        $context._analysisLayer.push(m);",
    "                    }",
    "                }",
    "            }",
    "        }",
    "        if (result.total_pages <= page) break;",
    "    }",
    "",
    "    // Tri par distance",
    "    establishmentsInRadius.sort((a, b) => a.distance - b.distance);",
    "",
    "    const rows = establishmentsInRadius.slice(0, 40).map(e => `",
    "        <tr>",
    "            <td class=\"small font-weight-bold text-truncate\" style=\"max-width: 140px;\" title=\"${e.nom}\">${e.enseigne || e.nom}</td>",
    "            <td class=\"small\">${e.ville}</td>",
    "            <td class=\"small text-right text-nowrap\">${e.distance.toFixed(1)} km</td>",
    "        </tr>",
    "    `).join('');",
    "",
    "    return {",
    "        html: `",
    "            <div class=\"mt-2\">",
    "                <p class=\"small mb-2\"><strong>${establishmentsInRadius.length} établissements</strong> trouvés dans les 50km.</p>",
    "                <div class=\"table-responsive\" style=\"max-height: 300px;\">",
    "                    <table class=\"table table-sm table-hover table-striped\">",
    "                        <thead class=\"thead-light\">",
    "                            <tr>",
    "                                <th class=\"small\">Enseigne</th>",
    "                                <th class=\"small\">Ville</th>",
    "                                <th class=\"small text-right\">Dist.</th>",
    "                            </tr>",
    "                        </thead>",
    "                        <tbody>${rows}</tbody>",
    "                    </table>",
    "                </div>",
    "                <p class=\"x-small text-muted mt-2\">Basé sur les établissements locaux (SIRET) et non les sièges sociaux.</p>",
    "            </div>",
    "        `,",
    "        data: establishmentsInRadius,",
    "        reset: clearLayer",
    "    };",
    "",
    "} catch (error) {",
    "    console.error(error);",
    "    return { html: '<div class=\"alert alert-danger small\">Erreur lors du filtrage géographique.</div>', data: [], reset: clearLayer };",
    "}"
  ],
  "description": "Cette analyse identifie les établissements physiques (agences, magasins, bureaux) situés dans un rayon de 50 km. Contrairement à une recherche classique qui peut pointer vers le siège social national, cette version utilise les coordonnées exactes de chaque établissement local pour garantir la pertinence géographique.",
  "title": "Établissements locaux (Rayon 50km)",
  "output": {
    "nom": "string",
    "enseigne": "string",
    "ville": "string",
    "distance": "number",
    "lat": "number",
    "lng": "number"
  },
  "mode": "SINGLE-POINT",
  "ownerId": "renaud.pawlak.dev481@agentforce.com",
  "tags": [ "france", "esn", "établissements locaux" ]
}